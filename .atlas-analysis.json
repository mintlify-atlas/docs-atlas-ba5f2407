  "keyFeatures": [
    "Shopify Hydrogen framework integration",
    "Sanity CMS for structured content management",
    "Custom useSanityQuery hook for unified data fetching",
    "Server and client component architecture",
    "Product listing pages (PLPs) and product detail pages (PDPs)",
    "Editorial pages with Portable Text support",
    "Responsive design with Tailwind CSS",
    "Product variant URL support",
    "Cart functionality"
  ],
  "publicApiSurface": [
    "useSanityQuery - Hook for fetching Sanity and Shopify data",
    "useSanityGraphQLQuery - GraphQL variant of useSanityQuery",
    "useProductsContext - Hook for accessing product data context",
    "ProductsProvider - Context provider for product data",
    "CartProvider - Context provider for cart state",
    "LinkProduct - Component for product links with variant support",
    "PortableText - Component for rendering Sanity Portable Text",
    "ProductCard - Server component for product display",
    "ProductDetails - Client component for product information",
    "ProductGallery - Client component for product images",
    "CollectionCard - Client component for collection display",
    "SanityImage - Client component for Sanity image rendering"
  ]
}
